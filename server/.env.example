# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# SendGrid API key (from https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=

# Verified sender address in SendGrid
EMAIL_FROM=

# Legacy SMTP / Gmail app-password fields (used by test-mail.js)
EMAIL_USER=
EMAIL_PASS=
